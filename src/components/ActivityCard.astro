---
// ActivityCard.astro
// Displays an activity/attraction card with booking link (e.g. Viator)

interface Props {
  name: string;
  description: string;
  imageUrl: string;
  ageRange: string;
  priceRange: string;
  address: string;
  bookingUrl?: string;
  bookingLabel?: string;
}

const {
  name,
  description,
  imageUrl,
  ageRange,
  priceRange,
  address,
  bookingUrl,
  bookingLabel = 'Book on Viator',
} = Astro.props;
---

<div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow duration-300 my-6">
  <div class="flex flex-col md:flex-row">
    <div class="md:w-64 h-48 md:h-auto shrink-0 overflow-hidden">
      <img
        src={imageUrl}
        alt={name}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="p-5 flex flex-col justify-between flex-1">
      <div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">{name}</h3>
        <p class="text-gray-600 text-sm mb-4 leading-relaxed">{description}</p>
        <div class="flex flex-wrap gap-3 mb-4">
          <span class="inline-flex items-center gap-1.5 text-xs font-medium bg-blue-50 text-blue-700 px-3 py-1.5 rounded-full">
            <span>👶</span> {ageRange}
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium bg-green-50 text-green-700 px-3 py-1.5 rounded-full">
            <span>💰</span> {priceRange}
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium bg-purple-50 text-purple-700 px-3 py-1.5 rounded-full">
            <span>📍</span> {address}
          </span>
        </div>
      </div>
      {bookingUrl && (
        <div>
          <a
            href={bookingUrl}
            target="_blank"
            rel="nofollow sponsored"
            class="inline-flex items-center gap-1 bg-primary hover:bg-primary-dark text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors duration-200"
          >
            {bookingLabel} →
          </a>
        </div>
      )}
    </div>
  </div>
</div>