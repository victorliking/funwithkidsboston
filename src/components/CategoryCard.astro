---
// CategoryCard.astro
// Homepage category entry card with hover animation

interface Props {
  title: string;
  description: string;
  href: string;
  emoji: string;
}

const { title, description, href, emoji } = Astro.props;
---

<a href={href} class="group block">
  <div class="bg-white rounded-xl shadow-md border border-gray-100 p-6 text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full">
    <div class="text-5xl mb-4">{emoji}</div>
    <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary transition-colors duration-200">
      {title}
    </h3>
    <p class="text-gray-500 text-sm leading-relaxed">{description}</p>
  </div>
</a>