---
// BaseLayout.astro
// Main site layout with navigation, SEO meta tags, and footer

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Styles -->
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 text-gray-800">
    <!-- Navigation -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="text-xl font-extrabold text-primary hover:text-primary-dark transition-colors">
            FunWithKidsBoston<span class="ml-1">🎉</span>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/category/Things To Do/" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">Things To Do</a>
            <a href="/category/Day Trips/" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">Day Trips</a>
            <a href="/category/Gear & Reviews/" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">Gear & Reviews</a>
            <a href="/category/Seasonal Guides/" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">Seasonal</a>
            <a href="/about/" class="text-sm font-medium text-gray-600 hover:text-primary transition-colors">About</a>
          </div>

          <!-- Mobile Hamburger (pure CSS) -->
          <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
          <label for="mobile-menu-toggle" class="md:hidden flex flex-col justify-center items-center w-10 h-10 cursor-pointer gap-1.5">
            <span class="block w-6 h-0.5 bg-gray-700 transition-all peer-checked:rotate-45 peer-checked:translate-y-2"></span>
            <span class="block w-6 h-0.5 bg-gray-700 transition-all peer-checked:opacity-0"></span>
            <span class="block w-6 h-0.5 bg-gray-700 transition-all peer-checked:-rotate-45 peer-checked:-translate-y-2"></span>
          </label>
        </div>

        <!-- Mobile Menu -->
        <div class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-96 transition-all duration-300">
          <div class="pb-4 flex flex-col gap-2">
            <a href="/category/Things To Do/" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors">Things To Do</a>
            <a href="/category/Day Trips/" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors">Day Trips</a>
            <a href="/category/Gear & Reviews/" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors">Gear & Reviews</a>
            <a href="/category/Seasonal Guides/" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors">Seasonal</a>
            <a href="/about/" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors">About</a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brand -->
          <div>
            <a href="/" class="text-xl font-extrabold text-white">FunWithKidsBoston 🎉</a>
            <p class="mt-3 text-sm leading-relaxed">
              Your go-to guide for family fun in the Greater Boston area. Written by local parents who love exploring the city with their kids.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="text-white font-semibold mb-4">Explore</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/category/Things To Do/" class="hover:text-white transition-colors">Things To Do</a></li>
              <li><a href="/category/Day Trips/" class="hover:text-white transition-colors">Day Trips</a></li>
              <li><a href="/category/Gear & Reviews/" class="hover:text-white transition-colors">Gear & Reviews</a></li>
              <li><a href="/category/Seasonal Guides/" class="hover:text-white transition-colors">Seasonal Guides</a></li>
            </ul>
          </div>

          <!-- Info -->
          <div>
            <h4 class="text-white font-semibold mb-4">Info</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/about/" class="hover:text-white transition-colors">About Us</a></li>
              <li><a href="/disclosure/" class="hover:text-white transition-colors">Affiliate Disclosure</a></li>
            </ul>
            <!-- Social placeholder -->
            <div class="flex gap-4 mt-6">
              <span class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center text-xs hover:bg-gray-600 transition-colors cursor-pointer" title="Instagram">📷</span>
              <span class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center text-xs hover:bg-gray-600 transition-colors cursor-pointer" title="Facebook">📘</span>
              <span class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center text-xs hover:bg-gray-600 transition-colors cursor-pointer" title="Pinterest">📌</span>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-10 pt-6 text-center text-xs">
          <p>© {new Date().getFullYear()} FunWithKidsBoston.com. All rights reserved.</p>
          <p class="mt-1">
            <a href="/disclosure/" class="hover:text-white transition-colors">Affiliate Disclosure</a>
            <span class="mx-2">·</span>
            <a href="/about/" class="hover:text-white transition-colors">About</a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>