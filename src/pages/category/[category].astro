---
// src/pages/category/[category].astro
// Dynamic category page that filters posts by category

import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const categories = ['Things To Do', 'Day Trips', 'Gear & Reviews', 'Seasonal Guides'];

  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: allPosts
        .filter((post) => post.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  category: string;
  posts: any[];
}

const { category, posts } = Astro.props;

const categoryDescriptions: Record<string, string> = {
  'Things To Do': 'Discover the best museums, parks, playgrounds, and local attractions for families in the Boston area.',
  'Day Trips': 'Weekend adventures and road trips within a few hours of Boston — perfect for families with kids.',
  'Gear & Reviews': 'Honest reviews and recommendations for family gear, from strollers to rain boots.',
  'Seasonal Guides': 'The best family activities for every season in New England.',
};

const categoryEmojis: Record<string, string> = {
  'Things To Do': '🎠',
  'Day Trips': '🚗',
  'Gear & Reviews': '🎒',
  'Seasonal Guides': '🍂',
};
---

<BaseLayout
  title={`${category} – FunWithKidsBoston`}
  description={categoryDescriptions[category] || `Browse all ${category} articles on FunWithKidsBoston.`}
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <!-- Category Header -->
    <div class="text-center mb-12">
      <span class="text-5xl mb-4 block">{categoryEmojis[category] || '📝'}</span>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-3">{category}</h1>
      <p class="text-gray-500 max-w-xl mx-auto">
        {categoryDescriptions[category] || `All articles in ${category}.`}
      </p>
    </div>

    <!-- Posts Grid -->
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            slug={post.id}
            category={post.data.category}
            ageRange={post.data.ageRange}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-gray-400 text-lg">No articles in this category yet. Check back soon!</p>
        <a href="/" class="inline-block mt-4 text-primary font-semibold hover:underline">← Back to Home</a>
      </div>
    )}
  </section>
</BaseLayout>